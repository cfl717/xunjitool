{
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "material": {
          "certpath": "./signing/debug.cer",
          "profile": "./signing/debug.p7b",
          "keystore": {
            "path": "./signing/debug.p12",
            "keyalias": "debugKey",
            "storepass": "",
            "keypass": ""
          }
        }
      }
    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "bundleName": "com.cfl.xunjitool",
        "bundleType": "app",
        "compileSdkVersion": "6.1.1(24)",
        "compatibleSdkVersion": "6.1.1(24)",
        "runtimeOS": "HarmonyOS",
        "targetSdkVersion": "6.1.1(24)"
      }
    ],
    "modules": [
      {
        "name": "entry",
        "srcPath": "./entry",
        "targets": [
          {
            "name": "default",
            "applyToProducts": ["default"]
          }
        ]
      }
    ]
  }
}
